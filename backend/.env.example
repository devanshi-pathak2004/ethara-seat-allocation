# --- Backend configuration ---

# Database. Leave unset to use the bundled SQLite file (great for local demos).
# For Postgres (Render/Railway) set the full connection string, e.g.:
# DATABASE_URL=postgresql://user:pass@host:5432/ethara
# DATABASE_URL=

# Comma-separated list of allowed frontend origins for CORS.
# Use "*" for the demo, or lock it down to your deployed frontend URL.
CORS_ORIGINS=*

# Optional: enable the LLM-backed assistant path (the rule-based engine is
# always the reliable fallback and needs no key).
# OPENAI_API_KEY=
